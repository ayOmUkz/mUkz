//@version=6
// ============================================================================
// VP Big Opportunity Engine
// Volume Profile + Auction Market Theory big-opportunity detector for ES/NQ.
// See BLUEPRINT.md for the full design.
//
// Build status: Step 12 of 12 (alerts) — v1 complete.
// Locked v1 decisions: Pine v6, RTH default with ETH toggle,
// ta.requestVolumeDelta as sole CVD source, single combined indicator.
// ============================================================================
indicator("VP Big Opportunity Engine", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500)


// ─── 1. INPUTS ──────────────────────────────────────────────────────────────

// Group 1: Session
g_session = "Session"
i_rthSession    = input.session("0930-1600", "RTH session",                                   group=g_session, tooltip="Default ES/NQ regular hours.")
i_useEth        = input.bool(false,          "Use ETH (24h) instead of RTH",                  group=g_session, tooltip="ETH treats the entire day as one profile period (anchored at chart-day rollover).")
i_timezone      = input.string("America/New_York", "Session timezone",                        group=g_session)
i_priorSessions = input.int(1, "Prior sessions to render (max 5)", minval=1, maxval=5,        group=g_session)

// Group 2: Profile resolution
g_profile = "Profile resolution"
i_rowMode    = input.string("Auto by ATR", "Row size mode", options=["Auto by ATR", "Ticks", "Points"], group=g_profile)
i_rowTicks   = input.int(4,    "Row size (ticks) — Ticks mode",     minval=1,             group=g_profile)
i_rowPoints  = input.float(0.25, "Row size (points) — Points mode", minval=0.01, step=0.01, group=g_profile)
i_atrMult    = input.float(0.10, "Auto row = ATR(14) ×",            minval=0.01, step=0.01, group=g_profile)
i_vaPct      = input.float(70.0, "Value Area %",                    minval=50.0, maxval=95.0, step=1.0, group=g_profile)
i_ltfMinutes = input.int(1,      "Lower-TF minutes for volume-by-price", minval=1, maxval=60, group=g_profile, tooltip="If chart TF ≤ this, the script falls back to current-bar volume distribution.")
i_histogramBars = input.int(30,  "Histogram width (bars)",  minval=5, maxval=200, group=g_profile, tooltip="Visual width of the developing-profile histogram (Step 2 sanity render).")

// Group 3: HVN / LVN
g_nodes = "HVN / LVN"
i_hvnMult     = input.float(1.5, "HVN threshold (× median bin)", minval=1.0,             step=0.1,  group=g_nodes)
i_lvnMult     = input.float(0.4, "LVN threshold (× median bin)", minval=0.05, maxval=1.0, step=0.05, group=g_nodes)
i_lvnMinTicks = input.int(2,     "Min LVN run width (ticks)",    minval=1,                          group=g_nodes)

// Group 4: Order flow
g_flow = "Order flow"
i_cvdLookback     = input.int(20,   "CVD divergence lookback (bars)",                       minval=5, group=g_flow)
i_absorptionMult  = input.float(2.0, "Absorption: |delta| ≥ this × stdev with stalled range", minval=1.0, step=0.1, group=g_flow)

// Group 5: Detection sensitivity
g_detect = "Detection sensitivity"
i_minOutBars            = input.int(3,   "Min bars outside VA = breakout",                     minval=1, group=g_detect)
i_acceptBars            = input.int(5,   "Min bars holding outside VA = acceptance",           minval=2, group=g_detect)
i_pocMigrationTicks     = input.int(4,   "POC migration threshold (ticks across lookback)",    minval=1, group=g_detect)
i_pocMigrationLookback  = input.int(10,  "POC migration lookback (bars)",                      minval=2, group=g_detect)
i_stretchAtr            = input.float(2.5, "POC magnet stretch (ATR multiples)", minval=0.5, step=0.1, group=g_detect)

// Group 6: Scoring weights & grade cutoffs
g_score = "Scoring & grades"
i_wLocation   = input.int(25, "Weight: Location alignment",        minval=0, maxval=100, group=g_score)
i_wTrap       = input.int(25, "Weight: Trap quality",              minval=0, maxval=100, group=g_score)
i_wQuality    = input.int(20, "Weight: Acceptance/rejection quality", minval=0, maxval=100, group=g_score)
i_wFlow       = input.int(20, "Weight: Order flow confirmation",   minval=0, maxval=100, group=g_score)
i_wTarget     = input.int(10, "Weight: Target clarity",            minval=0, maxval=100, group=g_score)
i_gradeAplus  = input.int(85, "A+ grade cutoff",                   minval=0, maxval=100, group=g_score)
i_gradeA      = input.int(70, "A grade cutoff",                    minval=0, maxval=100, group=g_score)
i_gradeB      = input.int(55, "B grade cutoff",                    minval=0, maxval=100, group=g_score)

// Group 7: Visuals
g_visual = "Visuals"
i_showProfile     = input.bool(true,  "Show profile lines (POC/VAH/VAL)",     group=g_visual)
i_showNodes       = input.bool(true,  "Show HVN/LVN bands",                   group=g_visual)
i_showRegimeBg    = input.bool(true,  "Tint background by auction state",     group=g_visual)
i_showDashboard   = input.bool(true,  "Show dashboard table",                 group=g_visual)
i_dashboardPos    = input.string("top_right", "Dashboard position", options=["top_right","top_left","middle_right","middle_left","bottom_right","bottom_left"], group=g_visual)
i_showSessionDbg  = input.bool(true,  "Step 1 debug: show session markers + tint", group=g_visual, tooltip="Verifies session detection. Will be removed once auction-state regime tint takes over.")
i_showDevHistogram = input.bool(true, "Step 2 debug: show developing profile histogram", group=g_visual, tooltip="Sideways histogram of the developing-session volume profile. Sanity-check vs TradingView's built-in VP.")
i_showFlowDbg     = input.bool(true,  "Step 5 debug: show CVD divergence + absorption markers", group=g_visual)

// Group 7b: Setup toggles
g_toggles = "Setup toggles"
i_enableS1 = input.bool(true, "S1: Failed Breakdown Below VAL (long)", group=g_toggles)
i_enableS2 = input.bool(true, "S2: Failed Breakout Above VAH (short)", group=g_toggles)
i_enableS3 = input.bool(true, "S3: 80% Value Rotation",                group=g_toggles)
i_enableS4 = input.bool(true, "S4: Initiative Expansion ↑",            group=g_toggles)
i_enableS5 = input.bool(true, "S5: Initiative Expansion ↓",            group=g_toggles)
i_enableS6 = input.bool(true, "S6: LVN Air Pocket Move",               group=g_toggles)
i_enableS7 = input.bool(true, "S7: POC Magnet Inventory Unwind",       group=g_toggles)


// ─── 2. SESSION ─────────────────────────────────────────────────────────────

// inSessionRTH is true on bars whose time falls inside the user-defined RTH window.
// time(tf, session, tz) returns na outside the session.
inSessionRTH = not na(time(timeframe.period, i_rthSession, i_timezone))

// In ETH mode, every bar is treated as in-session; profile periods anchor on
// the chart-day rollover instead of the RTH window.
inSession = i_useEth ? true : inSessionRTH

// newAnchor marks the first bar of a new profile period:
//   RTH: first bar entering the RTH window.
//   ETH: first bar of a new chart-day (limitation: not the CME 17:00 ET reset; v2 candidate).
isNewDay  = ta.change(time("1D")) != 0
newAnchor = i_useEth ? isNewDay : (inSessionRTH and not inSessionRTH[1])

// barsSinceAnchor — diagnostic + used by future steps for min-history gates.
var int barsSinceAnchor = 0
if newAnchor
    barsSinceAnchor := 1
else if inSession
    barsSinceAnchor += 1
else
    barsSinceAnchor := 0

// Bars-elapsed counter inside the active session period.
// Read this AFTER newAnchor to know if we have enough data to compute a profile.
sessionStartEvent = newAnchor
sessionEndEvent   = not i_useEth and (not inSessionRTH and inSessionRTH[1])

// Computed row size in price units. Centralized so every downstream step uses
// the same grid. Auto mode adapts to instrument volatility via ATR.
atrVal = ta.atr(14)
f_rowSize() =>
    switch i_rowMode
        "Ticks"  => i_rowTicks  * syminfo.mintick
        "Points" => i_rowPoints
        => atrVal * i_atrMult
rowSize = f_rowSize()


// ─── 3. VOLUME-BY-PRICE ─────────────────────────────────────────────────────
// Aggregates volume into a session-anchored bin grid using lower-timeframe
// (LTF) bars. Each LTF bar's volume is distributed pro-rata across the price
// bins it spans. Two maps are maintained: developing (live) and prior
// (snapshotted on newAnchor). Map key = integer bin index; value = volume.

// LTF bar UDT — collects what we need from each LTF bar in one fetch.
type ltfBarT
    float lo
    float hi
    float vol

f_mkLtfBar() => ltfBarT.new(low, high, volume)

// Decide whether the requested LTF is actually lower than the chart TF.
// If not (e.g., 1m chart with i_ltfMinutes=1), we fall back to the chart bar
// itself as a single "LTF bar". This keeps the indicator usable on tiny TFs.
chartSeconds = timeframe.in_seconds()
ltfSeconds   = i_ltfMinutes * 60
ltfActive    = ltfSeconds < chartSeconds

ltfBarsRaw = ltfActive
   ? request.security_lower_tf(syminfo.tickerid, str.tostring(i_ltfMinutes), f_mkLtfBar())
   : array.new<ltfBarT>()

// Bin helpers — parameterized so dev and prior profiles can each carry their
// own (anchor, rowSize). This matters because rowSize can drift across
// sessions when in Auto-by-ATR mode.
f_binIdx(p, anchor, rs)      => rs > 0 and not na(anchor) ? int(math.floor((p - anchor) / rs)) : int(na)
f_binBottom(idx, anchor, rs) => anchor + idx * rs
f_binTop(idx, anchor, rs)    => anchor + (idx + 1) * rs

f_addVolToBin(m, idx, v) =>
    if not na(idx) and v > 0
        cur = m.get(idx)
        m.put(idx, (na(cur) ? 0.0 : cur) + v)

// Distribute one LTF bar's volume across overlapping bins (linear pro-rata).
// Zero-range bars (lo == hi) drop the full volume into the single covering bin.
f_distributeLtfBar(m, b, anchor, rs) =>
    if b.vol > 0 and not na(anchor) and rs > 0
        if b.hi == b.lo
            f_addVolToBin(m, f_binIdx(b.lo, anchor, rs), b.vol)
        else
            range = b.hi - b.lo
            loIdx = f_binIdx(b.lo, anchor, rs)
            hiIdx = f_binIdx(b.hi, anchor, rs)
            if not na(loIdx) and not na(hiIdx)
                for i = loIdx to hiIdx
                    binBot = f_binBottom(i, anchor, rs)
                    binTop = f_binTop(i, anchor, rs)
                    overlap = math.min(b.hi, binTop) - math.max(b.lo, binBot)
                    if overlap > 0
                        f_addVolToBin(m, i, b.vol * (overlap / range))

// Per-profile state. Anchor + rowSize are locked at session start so the
// keys remain meaningful for the lifetime of the profile.
var map<int, float> devVolMap    = map.new<int, float>()
var map<int, float> priorVolMap  = map.new<int, float>()
var float           devAnchor    = na
var float           priorAnchor  = na
var float           devRowSize   = na
var float           priorRowSize = na
var int             devStartBar  = na
var int             priorStartBar = na

// Snapshot dev → prior on newAnchor, then reset dev with current open + rowSize.
// Done BEFORE aggregating this bar so the fresh anchor is valid for it.
if newAnchor and barstate.isconfirmed
    priorVolMap.clear()
    devKeys = devVolMap.keys()
    for k in devKeys
        priorVolMap.put(k, devVolMap.get(k))
    priorAnchor   := devAnchor
    priorRowSize  := devRowSize
    priorStartBar := devStartBar
    devVolMap.clear()
    devAnchor     := open
    devRowSize    := rowSize
    devStartBar   := bar_index

// Aggregate this bar's LTF volumes into developing. Confirmed-only to prevent
// intra-bar double counting on the live bar.
if barstate.isconfirmed and inSession and not na(devAnchor)
    if ltfActive
        for b in ltfBarsRaw
            f_distributeLtfBar(devVolMap, b, devAnchor, devRowSize)
    else
        f_distributeLtfBar(devVolMap, ltfBarT.new(low, high, volume), devAnchor, devRowSize)

// Diagnostic: total developing-session volume (used by data window).
var float devTotalVol = 0.0
if barstate.isconfirmed
    devTotalVol := 0.0
    devKeys2 = devVolMap.keys()
    for k in devKeys2
        devTotalVol += devVolMap.get(k)


// ─── 4. PROFILE METRICS ─────────────────────────────────────────────────────
// Builds POC / VAH / VAL from a bin map. Pure: depends only on its inputs.
// VA expansion: starting from POC, repeatedly add the larger-volume neighbor
// (above or below the accepted range) until cumulative volume ≥ vaPct% of
// total. Ties favor the upper bin (a common Market Profile convention).

f_buildProfile(m, anchor, rs, vaPct) =>
    pocFinal = float(na)
    vahFinal = float(na)
    valFinal = float(na)
    keys = m.keys()
    n = array.size(keys)
    if n > 0 and not na(anchor) and rs > 0
        // Pass 1: total volume, POC bin, and observed key range.
        total  = 0.0
        maxV   = 0.0
        pocIdx = int(na)
        minIdx = int(na)
        maxIdx = int(na)
        for k in keys
            v = m.get(k)
            total += v
            if v > maxV
                maxV   := v
                pocIdx := k
            if na(minIdx) or k < minIdx
                minIdx := k
            if na(maxIdx) or k > maxIdx
                maxIdx := k
        if not na(pocIdx) and total > 0
            // Pass 2: expand value area outward from POC.
            target      = total * (vaPct / 100.0)
            accumulated = maxV
            topIdx      = pocIdx
            botIdx      = pocIdx
            while accumulated < target and (topIdx < maxIdx or botIdx > minIdx)
                aboveIdx = topIdx + 1
                belowIdx = botIdx - 1
                aboveRaw = aboveIdx <= maxIdx ? m.get(aboveIdx) : na
                belowRaw = belowIdx >= minIdx ? m.get(belowIdx) : na
                aboveVol = aboveIdx <= maxIdx ? (na(aboveRaw) ? 0.0 : aboveRaw) : -1.0
                belowVol = belowIdx >= minIdx ? (na(belowRaw) ? 0.0 : belowRaw) : -1.0
                if aboveVol < 0 and belowVol < 0
                    break
                if aboveVol >= belowVol
                    topIdx := aboveIdx
                    if aboveVol > 0
                        accumulated += aboveVol
                else
                    botIdx := belowIdx
                    if belowVol > 0
                        accumulated += belowVol
            pocFinal := f_binBottom(pocIdx, anchor, rs) + rs / 2.0
            vahFinal := f_binTop(topIdx, anchor, rs)
            valFinal := f_binBottom(botIdx, anchor, rs)
    [pocFinal, vahFinal, valFinal]

[devPOC,   devVAH,   devVAL]   = f_buildProfile(devVolMap,   devAnchor,   devRowSize,   i_vaPct)
[priorPOC, priorVAH, priorVAL] = f_buildProfile(priorVolMap, priorAnchor, priorRowSize, i_vaPct)


// ─── 5. HVN / LVN ───────────────────────────────────────────────────────────
// Identifies High-Volume and Low-Volume Node clusters from a bin map.
// HVN = contiguous bins each with volume ≥ hvnMult × median present-bin
// volume. LVN = contiguous bins each ≤ lvnMult × median, AND the bins on
// both sides of the cluster must have above-median volume (the "trough"
// has to be bordered by walls). Sparse maps: missing keys count as 0.

type zoneT
    int   topIdx
    int   botIdx
    float priceTop
    float priceBot
    float peakVol

f_findNodes(m, anchor, rs, hvnMult, lvnMult, lvnMinPrice) =>
    hvnZones = array.new<zoneT>()
    lvnZones = array.new<zoneT>()
    keys = m.keys()
    n = array.size(keys)
    if n >= 5 and not na(anchor) and rs > 0
        // Median of present-bin volumes (skip 0-volume gaps so a narrow
        // profile doesn't collapse the median to 0).
        vols = array.new<float>()
        minIdx = int(na)
        maxIdx = int(na)
        for k in keys
            v = m.get(k)
            array.push(vols, v)
            if na(minIdx) or k < minIdx
                minIdx := k
            if na(maxIdx) or k > maxIdx
                maxIdx := k
        medV = array.median(vols)
        hvnThresh = hvnMult * medV
        lvnThresh = lvnMult * medV
        // Cluster walk: scan contiguous range, opening/closing HVN and
        // LVN runs as bins cross the thresholds.
        hvnTop = int(na)
        hvnBot = int(na)
        hvnPeak = 0.0
        lvnTop = int(na)
        lvnBot = int(na)
        if medV > 0
            for i = minIdx to maxIdx
                raw = m.get(i)
                vol = na(raw) ? 0.0 : raw
                isHvn = vol >= hvnThresh
                isLvn = vol <= lvnThresh
                // HVN cluster — open/extend/close.
                if isHvn
                    if na(hvnTop)
                        hvnBot := i
                        hvnPeak := 0.0
                    hvnTop := i
                    if vol > hvnPeak
                        hvnPeak := vol
                else if not na(hvnTop)
                    z = zoneT.new(hvnTop, hvnBot, f_binTop(hvnTop, anchor, rs), f_binBottom(hvnBot, anchor, rs), hvnPeak)
                    array.push(hvnZones, z)
                    hvnTop := int(na)
                    hvnBot := int(na)
                    hvnPeak := 0.0
                // LVN cluster — open/extend/close. Closure validates that
                // the cluster is bordered above and below by ABOVE-median
                // volume (true "trough between walls").
                if isLvn
                    if na(lvnTop)
                        lvnBot := i
                    lvnTop := i
                else if not na(lvnTop)
                    width = (lvnTop - lvnBot + 1) * rs
                    bottomBorder = lvnBot - 1 >= minIdx ? m.get(lvnBot - 1) : na
                    topBorder    = lvnTop + 1 <= maxIdx ? m.get(lvnTop + 1) : na
                    belowVol = na(bottomBorder) ? 0.0 : bottomBorder
                    aboveVol = na(topBorder)    ? 0.0 : topBorder
                    if belowVol > medV and aboveVol > medV and width >= lvnMinPrice
                        z = zoneT.new(lvnTop, lvnBot, f_binTop(lvnTop, anchor, rs), f_binBottom(lvnBot, anchor, rs), 0.0)
                        array.push(lvnZones, z)
                    lvnTop := int(na)
                    lvnBot := int(na)
            // Flush any HVN cluster open at the top of the range. Open LVN
            // clusters at the edges have no upper wall and are discarded.
            if not na(hvnTop)
                z = zoneT.new(hvnTop, hvnBot, f_binTop(hvnTop, anchor, rs), f_binBottom(hvnBot, anchor, rs), hvnPeak)
                array.push(hvnZones, z)
    [hvnZones, lvnZones]

[devHvnZones,   devLvnZones]   = f_findNodes(devVolMap,   devAnchor,   devRowSize,   i_hvnMult, i_lvnMult, i_lvnMinTicks * syminfo.mintick)
[priorHvnZones, priorLvnZones] = f_findNodes(priorVolMap, priorAnchor, priorRowSize, i_hvnMult, i_lvnMult, i_lvnMinTicks * syminfo.mintick)


// ─── 6. ORDER FLOW ──────────────────────────────────────────────────────────
// Native ta.requestVolumeDelta gives buy-vs-sell volume per chart bar,
// computed from a lower TF. We cumulate it into a session-anchored CVD
// (reset on newAnchor), then derive slope, divergence vs price, and an
// absorption flag (large delta with stalled range).

// LTF for the delta request must be strictly lower than the chart TF.
// Cap to (chartMinutes - 1) on minute charts; fall back to "1S" on a
// chart of 1m or smaller.
maxDeltaLtfMins = math.max(1, int(chartSeconds / 60.0) - 1)
deltaLtfStr     = chartSeconds > 60 ? str.tostring(math.min(i_ltfMinutes, maxDeltaLtfMins)) : "1S"
barDelta        = ta.requestVolumeDelta(deltaLtfStr)

// Session-anchored CVD. Reset to 0 on newAnchor so the running sum reflects
// the current session only. Confirmed-only to prevent intra-bar drift.
var float sessionCvd = 0.0
if newAnchor and barstate.isconfirmed
    sessionCvd := 0.0
if inSession and barstate.isconfirmed and not na(barDelta)
    sessionCvd += barDelta

// CVD slope over the configured lookback. Positive → buyer pressure
// building; negative → seller pressure building.
cvdSlope = sessionCvd - sessionCvd[i_cvdLookback]

// Divergence detection. Compares the highest/lowest in the most recent
// lookback window against the same metric in the prior lookback window.
// Bear: price made a higher high but CVD did not.
// Bull: price made a lower low but CVD did not.
priceMaxNow  = ta.highest(high, i_cvdLookback)
priceMaxPrev = ta.highest(high, i_cvdLookback)[i_cvdLookback]
cvdMaxNow    = ta.highest(sessionCvd, i_cvdLookback)
cvdMaxPrev   = ta.highest(sessionCvd, i_cvdLookback)[i_cvdLookback]
priceMinNow  = ta.lowest(low, i_cvdLookback)
priceMinPrev = ta.lowest(low, i_cvdLookback)[i_cvdLookback]
cvdMinNow    = ta.lowest(sessionCvd, i_cvdLookback)
cvdMinPrev   = ta.lowest(sessionCvd, i_cvdLookback)[i_cvdLookback]

bearDivergence = barstate.isconfirmed and priceMaxNow > priceMaxPrev and cvdMaxNow < cvdMaxPrev
bullDivergence = barstate.isconfirmed and priceMinNow < priceMinPrev and cvdMinNow > cvdMinPrev

// Absorption: large |delta| paired with a stalled bar range. Direction
// follows the sign of the absorbed delta (positive delta absorbed means
// sellers absorbed the buying → bearish, and vice versa).
deltaStdev      = ta.stdev(barDelta, 50)
absorptionThres = i_absorptionMult * deltaStdev
typicalRange    = ta.atr(14)
isAbsorption    = barstate.isconfirmed and not na(deltaStdev) and deltaStdev > 0 and math.abs(barDelta) >= absorptionThres and (high - low) < typicalRange * 0.5
absorptionBull  = isAbsorption and barDelta < 0
absorptionBear  = isAbsorption and barDelta > 0


// ─── 7. AUCTION STATE MACHINE ───────────────────────────────────────────────
// Classifies each confirmed bar into one of: Balance / Failed Auction /
// Initiative Expansion / Repair Auction (Repair stays a placeholder until
// Step 8 brings the structural-repair primitives online). State is sticky
// — it persists until a transition condition fires, avoiding flip-flop on
// quiet bars.

// Excursion bar counters: how many consecutive bars closed outside prior VA.
var int barsAboveVAH = 0
var int barsBelowVAL = 0
if barstate.isconfirmed
    if not na(priorVAH) and close > priorVAH
        barsAboveVAH := barsAboveVAH + 1
    else
        barsAboveVAH := 0
    if not na(priorVAL) and close < priorVAL
        barsBelowVAL := barsBelowVAL + 1
    else
        barsBelowVAL := 0

// POC migration. Compares developing POC to its value `lookback` bars ago.
pocPrev           = devPOC[i_pocMigrationLookback]
pocChangePrice    = na(pocPrev) or na(devPOC) ? 0.0 : devPOC - pocPrev
pocMigrationTicks = pocChangePrice / syminfo.mintick
pocMigratingUp    = pocMigrationTicks >=  i_pocMigrationTicks
pocMigratingDown  = pocMigrationTicks <= -i_pocMigrationTicks
pocMigrating      = pocMigratingUp or pocMigratingDown

// Is current close inside the developing value area?
insideDevVA = not na(devVAH) and not na(devVAL) and close >= devVAL and close <= devVAH

// Transition conditions.
isInitiativeUp     = barsAboveVAH >= i_acceptBars and pocMigratingUp
isInitiativeDown   = barsBelowVAL >= i_acceptBars and pocMigratingDown
reclaimedFromAbove = not na(priorVAH) and barsAboveVAH == 0 and nz(barsAboveVAH[1]) >= 1
reclaimedFromBelow = not na(priorVAL) and barsBelowVAL == 0 and nz(barsBelowVAL[1]) >= 1

// Sticky state. Updated only when a transition condition fires; otherwise
// the previous classification carries forward.
var string auctionState = "Balance"
var string auctionBias  = "Neutral"

if barstate.isconfirmed
    if isInitiativeUp
        auctionState := "Initiative Expansion"
        auctionBias  := "Bullish"
    else if isInitiativeDown
        auctionState := "Initiative Expansion"
        auctionBias  := "Bearish"
    else if reclaimedFromAbove
        auctionState := "Failed Auction"
        auctionBias  := "Bearish"
    else if reclaimedFromBelow
        auctionState := "Failed Auction"
        auctionBias  := "Bullish"
    else if insideDevVA and not pocMigrating
        auctionState := "Balance"
        auctionBias  := "Neutral"


// ─── 8. CONTEXT METRICS ─────────────────────────────────────────────────────
// Helpers consumed by setups in Section 9. Composed from earlier sections
// (zones from §5, profile metrics from §4, state from §7).

// Bars-since-prior-VA-reclaim: how long has price been holding inside
// prior VA. Resets to 0 when price closes outside VA.
var int barsInsidePriorVA = 0
if barstate.isconfirmed
    insidePriorVA = not na(priorVAH) and not na(priorVAL) and close >= priorVAL and close <= priorVAH
    if insidePriorVA
        barsInsidePriorVA := barsInsidePriorVA + 1
    else
        barsInsidePriorVA := 0

// Distance helpers for clean targets. Return na if no qualifying zone.
f_nextHvnAbove(zones, price) =>
    out = float(na)
    bestDist = float(na)
    for z in zones
        if z.priceBot > price
            d = z.priceBot - price
            if na(bestDist) or d < bestDist
                bestDist := d
                out := z.priceBot
    out

f_nextHvnBelow(zones, price) =>
    out = float(na)
    bestDist = float(na)
    for z in zones
        if z.priceTop < price
            d = price - z.priceTop
            if na(bestDist) or d < bestDist
                bestDist := d
                out := z.priceTop
    out

f_nextLvnAbove(zones, price) =>
    out = float(na)
    bestDist = float(na)
    for z in zones
        if z.priceBot > price
            d = z.priceBot - price
            if na(bestDist) or d < bestDist
                bestDist := d
                out := z.priceBot
    out

f_nextLvnBelow(zones, price) =>
    out = float(na)
    bestDist = float(na)
    for z in zones
        if z.priceTop < price
            d = price - z.priceTop
            if na(bestDist) or d < bestDist
                bestDist := d
                out := z.priceTop
    out

// Convenience composites — pre-computed once per bar so Section 9 doesn't
// repeat the lookups.
nextHvnUpPrior   = f_nextHvnAbove(priorHvnZones, close)
nextHvnDownPrior = f_nextHvnBelow(priorHvnZones, close)

// LVN containment: find the LVN zone (if any) currently enclosing the
// price. Empty zoneT (priceBot=na) signals "no LVN here".
f_lvnContaining(zones, price) =>
    out = zoneT.new(0, 0, float(na), float(na), 0.0)
    for z in zones
        if price >= z.priceBot and price <= z.priceTop
            out := z
            break
    out

currentLvnPrior = f_lvnContaining(priorLvnZones, close)
currentLvnDev   = f_lvnContaining(devLvnZones,   close)
priceInLvn      = not na(currentLvnPrior.priceBot) or not na(currentLvnDev.priceBot)
priceInLvnPrev  = priceInLvn[1]
enteredLvn      = priceInLvn and not priceInLvnPrev

// Pick the active LVN (prior takes priority when both contain price).
activeLvnTop = not na(currentLvnPrior.priceBot) ? currentLvnPrior.priceTop : currentLvnDev.priceTop
activeLvnBot = not na(currentLvnPrior.priceBot) ? currentLvnPrior.priceBot : currentLvnDev.priceBot

// Volume expansion / contraction. Reference is a 20-bar SMA of volume.
volAvg20      = ta.sma(volume, 20)
volExpanding  = not na(volAvg20) and volAvg20 > 0 and volume >= volAvg20 * 1.25
volContracting= not na(volAvg20) and volAvg20 > 0 and volume <  volAvg20 * 0.9

// Stretch from developing POC, ATR-normalized. Used by S7 magnet setup.
stretchATR    = na(devPOC) or atrVal == 0 ? 0.0 : (close - devPOC) / atrVal

// Bar shape — biased momentum bar = body ≥ half of range.
bullishMomentumBar = close > open and (close - open) >= (high - low) * 0.5
bearishMomentumBar = close < open and (open - close) >= (high - low) * 0.5


// ─── 9. SETUP DETECTORS ─────────────────────────────────────────────────────
// Each setup outputs a setupT pushed onto activeSetups. Score/grade are
// filled in Step 10. Setups are detected per-confirmed-bar; the trigger
// bar is the bar that satisfies all conditions.

type setupT
    string name
    string side
    string code         // short code for chart label (e.g., "FB-VAL", "FB-VAH")
    int    score
    string grade
    float  target1
    float  target2
    float  target3
    float  invalidPrice

var array<setupT> activeSetups = array.new<setupT>()

// Did a divergence or absorption fire within the last `acceptBars` bars?
recentBullDiv      = nz(ta.barssince(bullDivergence),  99999) <= i_acceptBars
recentBearDiv      = nz(ta.barssince(bearDivergence),  99999) <= i_acceptBars
recentAbsorpBull   = nz(ta.barssince(absorptionBull),  99999) <= i_acceptBars
recentAbsorpBear   = nz(ta.barssince(absorptionBear),  99999) <= i_acceptBars

// S1 — Failed Breakdown Below VAL → LONG
// Trigger: previous bar(s) closed below priorVAL, current bar reclaims
// inside VA, and order-flow shows seller exhaustion (bull divergence
// during excursion OR a bullish absorption print near the low).
isS1 = i_enableS1 and barstate.isconfirmed and reclaimedFromBelow and (recentBullDiv or recentAbsorpBull)

// S2 — Failed Breakout Above VAH → SHORT (mirror of S1).
isS2 = i_enableS2 and barstate.isconfirmed and reclaimedFromAbove and (recentBearDiv or recentAbsorpBear)

// S3 — 80% Value Rotation. Session opens outside prior VA, then price
// reclaims VA and holds inside for ≥ acceptBars. Fires on the bar that
// CROSSES the holding threshold (not on every subsequent bar).
crossedAcceptInside = barsInsidePriorVA == i_acceptBars
isS3Long  = i_enableS3 and barstate.isconfirmed and crossedAcceptInside and not na(devAnchor) and not na(priorVAL) and devAnchor < priorVAL
isS3Short = i_enableS3 and barstate.isconfirmed and crossedAcceptInside and not na(devAnchor) and not na(priorVAH) and devAnchor > priorVAH

// S4 — Initiative Expansion Above VAH → LONG. Active initiative-bullish
// regime AND a pullback test that holds: current bar dipped to priorVAH
// (within a small buffer) and closed back above it.
buffer = 2 * syminfo.mintick
testingVAHFromAbove = not na(priorVAH) and low <= priorVAH + buffer and close > priorVAH
isS4 = i_enableS4 and barstate.isconfirmed and auctionState == "Initiative Expansion" and auctionBias == "Bullish" and testingVAHFromAbove

// S5 — Initiative Expansion Below VAL → SHORT (mirror of S4).
testingVALFromBelow = not na(priorVAL) and high >= priorVAL - buffer and close < priorVAL
isS5 = i_enableS5 and barstate.isconfirmed and auctionState == "Initiative Expansion" and auctionBias == "Bearish" and testingVALFromBelow

// S6 — LVN Air Pocket Move. Price just entered an LVN with expanding
// volume on a momentum bar; expect price to traverse to the next HVN.
isS6Long  = i_enableS6 and barstate.isconfirmed and enteredLvn and volExpanding and bullishMomentumBar
isS6Short = i_enableS6 and barstate.isconfirmed and enteredLvn and volExpanding and bearishMomentumBar

// S7 — POC Magnet Inventory Unwind. Price stretched ≥ stretchAtr × ATR
// from developing POC, with order-flow exhaustion (recent divergence) and
// drying volume → expect reversion toward POC.
overstretchedUp   = stretchATR >=  i_stretchAtr
overstretchedDown = stretchATR <= -i_stretchAtr
isS7Short = i_enableS7 and barstate.isconfirmed and overstretchedUp   and recentBearDiv and volContracting
isS7Long  = i_enableS7 and barstate.isconfirmed and overstretchedDown and recentBullDiv and volContracting

if barstate.isconfirmed
    array.clear(activeSetups)
    if isS1
        // Targets: priorPOC → priorVAH → next opposing HVN/poor high.
        // Invalidation: lowest low of the excursion (last 2 bars covers
        // the typical reclaim pattern).
        s1 = setupT.new(
                 "Failed Breakdown Below VAL", "long", "FB-VAL",
                 0, "",
                 not na(priorPOC) ? priorPOC : devPOC,
                 priorVAH,
                 na,
                 math.min(low, low[1]))
        array.push(activeSetups, s1)
    if isS2
        s2 = setupT.new(
                 "Failed Breakout Above VAH", "short", "FB-VAH",
                 0, "",
                 not na(priorPOC) ? priorPOC : devPOC,
                 priorVAL,
                 na,
                 math.max(high, high[1]))
        array.push(activeSetups, s2)
    if isS3Long
        s3l = setupT.new(
                  "80% Value Rotation Up", "long", "80%R↑",
                  0, "",
                  priorPOC,
                  priorVAH,
                  na,
                  priorVAL - buffer)
        array.push(activeSetups, s3l)
    if isS3Short
        s3s = setupT.new(
                  "80% Value Rotation Down", "short", "80%R↓",
                  0, "",
                  priorPOC,
                  priorVAL,
                  na,
                  priorVAH + buffer)
        array.push(activeSetups, s3s)
    if isS4
        s4 = setupT.new(
                 "Initiative Expansion Above VAH", "long", "IE↑",
                 0, "",
                 nextHvnUpPrior,
                 na,
                 na,
                 priorVAH - buffer)
        array.push(activeSetups, s4)
    if isS5
        s5 = setupT.new(
                 "Initiative Expansion Below VAL", "short", "IE↓",
                 0, "",
                 nextHvnDownPrior,
                 na,
                 na,
                 priorVAL + buffer)
        array.push(activeSetups, s5)
    if isS6Long
        s6l = setupT.new(
                  "LVN Air Pocket Up", "long", "LVN↑",
                  0, "",
                  nextHvnUpPrior,
                  na,
                  na,
                  not na(activeLvnBot) ? activeLvnBot - buffer : math.min(low, low[1]))
        array.push(activeSetups, s6l)
    if isS6Short
        s6s = setupT.new(
                  "LVN Air Pocket Down", "short", "LVN↓",
                  0, "",
                  nextHvnDownPrior,
                  na,
                  na,
                  not na(activeLvnTop) ? activeLvnTop + buffer : math.max(high, high[1]))
        array.push(activeSetups, s6s)
    if isS7Long
        s7l = setupT.new(
                  "POC Magnet Reversion Up", "long", "POC←",
                  0, "",
                  devPOC,
                  priorPOC,
                  na,
                  math.min(low, low[1]) - buffer)
        array.push(activeSetups, s7l)
    if isS7Short
        s7s = setupT.new(
                  "POC Magnet Reversion Down", "short", "POC←",
                  0, "",
                  devPOC,
                  priorPOC,
                  na,
                  math.max(high, high[1]) + buffer)
        array.push(activeSetups, s7s)


// ─── 10. SCORING ────────────────────────────────────────────────────────────
// Five-component score in [0..100]. Each scorer is pure and uses the
// configured weights from Section 1 as caps; default caps are 25/25/20/20/10.
// Grade thresholds (i_gradeAplus/A/B) translate score → grade label.

// Component 1: Location alignment. Full points when the trigger price is
// within 1 row of any structural level; linear decay to 0 at 5 rows.
f_scoreLocation(price, weight) =>
    out = 0
    if not na(price) and rowSize > 0
        levels = array.from(priorVAH, priorVAL, priorPOC, devVAH, devVAL, devPOC)
        bestRows = float(na)
        for lvl in levels
            if not na(lvl)
                d = math.abs(price - lvl) / rowSize
                if na(bestRows) or d < bestRows
                    bestRows := d
        if not na(bestRows)
            out := math.round(math.max(0.0, weight * (1.0 - bestRows / 5.0)))
    out

// Component 2: Trap quality. Setup-specific: failed-auctions weight the
// excursion length; initiative setups credit a moderate baseline; rotation
// and POC magnet setups have low intrinsic trap quality.
f_scoreTrap(code, weight) =>
    raw = switch code
        "FB-VAL" => math.min(weight, nz(barsBelowVAL[1]) * 5)
        "FB-VAH" => math.min(weight, nz(barsAboveVAH[1]) * 5)
        "IE↑"   => math.min(weight, math.max(barsAboveVAH, 0) * 3 + 5)
        "IE↓"   => math.min(weight, math.max(barsBelowVAL, 0) * 3 + 5)
        "80%R↑" => weight * 6 / 25
        "80%R↓" => weight * 6 / 25
        "LVN↑"  => weight * 8 / 25
        "LVN↓"  => weight * 8 / 25
        "POC←"  => weight * 10 / 25
        => 0
    int(math.round(raw))

// Component 3: Acceptance / rejection quality. Higher when the setup's
// signature is unambiguous (clean reclaim, sustained holding, momentum bar).
f_scoreQuality(code, side, weight) =>
    base = switch code
        "FB-VAL" => weight * 15 / 20
        "FB-VAH" => weight * 15 / 20
        "80%R↑" => weight * 18 / 20
        "80%R↓" => weight * 18 / 20
        "IE↑"   => weight * 15 / 20
        "IE↓"   => weight * 15 / 20
        "LVN↑"  => weight * 12 / 20
        "LVN↓"  => weight * 12 / 20
        "POC←"  => weight * 14 / 20
        => 0.0
    bonus = 0.0
    if (side == "long" and recentAbsorpBull) or (side == "short" and recentAbsorpBear)
        bonus := weight * 3 / 20
    int(math.round(math.min(weight, base + bonus)))

// Component 4: Order-flow confirmation. Direction (cvdSlope), divergence,
// and absorption signal all sum into the cap.
f_scoreFlow(side, weight) =>
    raw = 0.0
    if side == "long"
        if cvdSlope > 0
            raw += weight * 8 / 20
        if recentBullDiv
            raw += weight * 6 / 20
        if recentAbsorpBull
            raw += weight * 6 / 20
    else if side == "short"
        if cvdSlope < 0
            raw += weight * 8 / 20
        if recentBearDiv
            raw += weight * 6 / 20
        if recentAbsorpBear
            raw += weight * 6 / 20
    int(math.round(math.min(weight, raw)))

// Component 5: Target clarity. Full points when distance to the nearest
// opposing HVN is ≥ 1.5× distance to target1; partial when ≥ 1.0×.
f_scoreTarget(side, target1, weight) =>
    out = 0
    if not na(target1)
        tgtDist = math.abs(target1 - close)
        opposing = side == "long"
                   ? (na(nextHvnDownPrior) ? na : math.abs(close - nextHvnDownPrior))
                   : (na(nextHvnUpPrior)   ? na : math.abs(nextHvnUpPrior - close))
        if not na(opposing) and tgtDist > 0
            ratio = opposing / tgtDist
            out := ratio >= 1.5 ? weight : ratio >= 1.0 ? int(math.round(weight * 0.6)) : 0
        else
            out := int(math.round(weight * 0.5))
    out

f_scoreSetup(s) =>
    locS  = f_scoreLocation(close, i_wLocation)
    trapS = f_scoreTrap(s.code, i_wTrap)
    qualS = f_scoreQuality(s.code, s.side, i_wQuality)
    flowS = f_scoreFlow(s.side, i_wFlow)
    tgtS  = f_scoreTarget(s.side, s.target1, i_wTarget)
    locS + trapS + qualS + flowS + tgtS

f_grade(score) =>
    score >= i_gradeAplus ? "A+" :
       score >= i_gradeA  ? "A"  :
       score >= i_gradeB  ? "B"  : ""

// Score every active setup that detection produced this bar. UDT fields
// are mutable in Pine v6, so we update the existing struct in place.
if barstate.isconfirmed and array.size(activeSetups) > 0
    for i = 0 to array.size(activeSetups) - 1
        s = array.get(activeSetups, i)
        sc = f_scoreSetup(s)
        s.score := sc
        s.grade := f_grade(sc)


// ─── 11. RENDER ─────────────────────────────────────────────────────────────

// Step 1 sanity render — proves session detection works. Replaced once
// regime tint and profile lines arrive in later steps.
plotchar(i_showSessionDbg and sessionStartEvent and barstate.isconfirmed, "Anchor start", "▲", location.bottom, color=color.new(color.green, 0), size=size.tiny)
plotchar(i_showSessionDbg and sessionEndEvent   and barstate.isconfirmed, "Anchor end",   "▼", location.top,    color=color.new(color.red,   0), size=size.tiny)
bgcolor(i_showSessionDbg and inSession ? color.new(color.blue, 95) : na, title="In-session tint (debug)")

// Auction-state regime tint. Color coded by state + bias.
regimeColor = switch auctionState
    "Initiative Expansion" => auctionBias == "Bullish" ? color.new(color.green,  92) : color.new(color.red,   92)
    "Failed Auction"       => color.new(color.orange, 92)
    "Repair Auction"       => color.new(color.purple, 92)
    => color.new(color.gray, 95)
bgcolor(i_showRegimeBg ? regimeColor : na, title="Auction regime")

// Dashboard table — rendered only on the last bar; cells overwritten each
// realtime tick so the displayed numbers stay current.
f_dashPos(s) =>
    switch s
        "top_right"     => position.top_right
        "top_left"      => position.top_left
        "middle_right"  => position.middle_right
        "middle_left"   => position.middle_left
        "bottom_right"  => position.bottom_right
        "bottom_left"   => position.bottom_left
        => position.top_right

f_fmtPrice(p) => na(p) ? "—" : str.tostring(p, format.mintick)
f_fmtNum(p, fmt) => na(p) ? "—" : str.tostring(p, fmt)

f_gradeBg(g) =>
    switch g
        "A+" => color.new(color.lime,   30)
        "A"  => color.new(color.green,  50)
        "B"  => color.new(color.yellow, 50)
        => color.new(color.gray, 70)

f_stateBg(st, bias) =>
    switch st
        "Initiative Expansion" => bias == "Bullish" ? color.new(color.green, 60) : color.new(color.red, 60)
        "Failed Auction"       => color.new(color.orange, 60)
        "Repair Auction"       => color.new(color.purple, 60)
        => color.new(color.gray, 70)

var table dashboard = na

if barstate.islast and i_showDashboard
    if na(dashboard)
        dashboard := table.new(f_dashPos(i_dashboardPos), 3, 7, bgcolor=color.new(color.black, 70), border_color=color.new(color.gray, 50), border_width=1)

    // Pick the highest-scoring active setup for the headline row.
    activeName  = "—"
    activeGrade = ""
    activeScore = 0
    activeT1    = float(na)
    activeT2    = float(na)
    activeT3    = float(na)
    activeInv   = float(na)
    if array.size(activeSetups) > 0
        bestS = array.get(activeSetups, 0)
        for s in activeSetups
            if s.score > bestS.score
                bestS := s
        activeName  := bestS.name
        activeGrade := bestS.grade
        activeScore := bestS.score
        activeT1    := bestS.target1
        activeT2    := bestS.target2
        activeT3    := bestS.target3
        activeInv   := bestS.invalidPrice

    trappedLabel = barsAboveVAH > 0 ? "Trapped Longs" : barsBelowVAL > 0 ? "Trapped Shorts" : "—"
    volExpRatio  = nz(volAvg20, 0) > 0 ? volume / volAvg20 : na

    // Row 0 — auction state / bias / trapped side.
    table.cell(dashboard, 0, 0, "State: "  + auctionState, text_color=color.white, text_size=size.small, bgcolor=f_stateBg(auctionState, auctionBias))
    table.cell(dashboard, 1, 0, "Bias: "   + auctionBias,  text_color=color.white, text_size=size.small, bgcolor=f_stateBg(auctionState, auctionBias))
    table.cell(dashboard, 2, 0, trappedLabel,              text_color=color.white, text_size=size.small)

    // Row 1 — active setup / grade / score.
    table.cell(dashboard, 0, 1, "Setup: " + activeName,                       text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 1, "Grade: " + (activeGrade == "" ? "—" : activeGrade), text_color=color.white, text_size=size.small, bgcolor=f_gradeBg(activeGrade))
    table.cell(dashboard, 2, 1, "Score: " + str.tostring(activeScore),        text_color=color.white, text_size=size.small)

    // Row 2 — targets.
    table.cell(dashboard, 0, 2, "T1: "  + f_fmtPrice(activeT1), text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 2, "T2: "  + f_fmtPrice(activeT2), text_color=color.white, text_size=size.small)
    table.cell(dashboard, 2, 2, "T3: "  + f_fmtPrice(activeT3), text_color=color.white, text_size=size.small)

    // Row 3 — invalidation level.
    table.cell(dashboard, 0, 3, "Invalid: " + f_fmtPrice(activeInv), text_color=color.white, text_size=size.small)
    table.cell(dashboard, 1, 3, "", bgcolor=color.new(color.gray, 90))
    table.cell(dashboard, 2, 3, "", bgcolor=color.new(color.gray, 90))

    // Row 4 — developing profile metrics.
    table.cell(dashboard, 0, 4, "dPOC: " + f_fmtPrice(devPOC), text_color=color.orange, text_size=size.small)
    table.cell(dashboard, 1, 4, "dVAH: " + f_fmtPrice(devVAH), text_color=color.teal,   text_size=size.small)
    table.cell(dashboard, 2, 4, "dVAL: " + f_fmtPrice(devVAL), text_color=color.teal,   text_size=size.small)

    // Row 5 — prior profile metrics.
    table.cell(dashboard, 0, 5, "pPOC: " + f_fmtPrice(priorPOC), text_color=color.new(color.orange, 0), text_size=size.small)
    table.cell(dashboard, 1, 5, "pVAH: " + f_fmtPrice(priorVAH), text_color=color.new(color.teal,   0), text_size=size.small)
    table.cell(dashboard, 2, 5, "pVAL: " + f_fmtPrice(priorVAL), text_color=color.new(color.teal,   0), text_size=size.small)

    // Row 6 — order-flow + stretch context.
    table.cell(dashboard, 0, 6, "CVD slope: " + f_fmtNum(cvdSlope,   "#.##"), text_color=color.gray, text_size=size.small)
    table.cell(dashboard, 1, 6, "Vol exp: "   + f_fmtNum(volExpRatio,"#.##"), text_color=color.gray, text_size=size.small)
    table.cell(dashboard, 2, 6, "Stretch: "   + f_fmtNum(stretchATR, "#.##"), text_color=color.gray, text_size=size.small)

// Setup labels — placed at the trigger bar. Persist as historical markers.
// Tooltip carries the full setup name + score breakdown; the on-chart code
// stays terse. Size scales with grade so A+ setups are visually dominant.
if barstate.isconfirmed
    for s in activeSetups
        labelColor = s.side == "long" ? color.new(color.green, 0) : color.new(color.red, 0)
        labelStyle = s.side == "long" ? label.style_label_up : label.style_label_down
        labelY     = s.side == "long" ? low : high
        labelText  = s.grade == "" ? s.code : s.code + " " + s.grade
        labelSize  = s.grade == "A+" ? size.large  :
                     s.grade == "A"  ? size.normal :
                     s.grade == "B"  ? size.small  : size.tiny
        tip        = s.name + " | score=" + str.tostring(s.score) + " | T1=" + str.tostring(s.target1) + " | inv=" + str.tostring(s.invalidPrice)
        label.new(bar_index, labelY, labelText, color=labelColor, textcolor=color.white, style=labelStyle, size=labelSize, tooltip=tip)

// Diagnostic plots — visible only in the Data Window.
plot(rowSize,          "Row size (price)",          color=color.new(color.gray, 60), display=display.data_window)
plot(barsSinceAnchor,  "Bars since anchor",         color=color.new(color.gray, 60), display=display.data_window)
plot(devTotalVol,      "Dev session total volume",  color=color.new(color.gray, 60), display=display.data_window)
plot(ltfActive ? 1 : 0,"LTF active (1=yes, 0=fallback)", color=color.new(color.gray, 60), display=display.data_window)
plot(barDelta,         "Bar delta",                 color=color.new(color.gray, 60), display=display.data_window)
plot(sessionCvd,       "Session CVD",               color=color.new(color.gray, 60), display=display.data_window)
plot(cvdSlope,         "CVD slope (lookback)",      color=color.new(color.gray, 60), display=display.data_window)
plot(stretchATR,       "Stretch from POC (ATR)",    color=color.new(color.gray, 60), display=display.data_window)
plot(volume / nz(volAvg20, volume), "Vol expansion ratio",  color=color.new(color.gray, 60), display=display.data_window)

// Step 5 sanity markers — divergence + absorption events. Will be folded
// into the dashboard table once Step 11 lands.
plotchar(i_showFlowDbg and bullDivergence, "Bull div",       "ᵇ", location.belowbar, color=color.new(color.lime,   0), size=size.tiny)
plotchar(i_showFlowDbg and bearDivergence, "Bear div",       "ᵇ", location.abovebar, color=color.new(color.red,    0), size=size.tiny)
plotchar(i_showFlowDbg and absorptionBull, "Absorption bull","ᵃ", location.belowbar, color=color.new(color.lime,   0), size=size.small)
plotchar(i_showFlowDbg and absorptionBear, "Absorption bear","ᵃ", location.abovebar, color=color.new(color.red,    0), size=size.small)

// Profile lines. Prior values are solid + bold (frozen levels), developing
// values are translucent (live).
plot(i_showProfile ? priorPOC : na, "pPOC", color=color.new(color.orange,  0), style=plot.style_linebr, linewidth=2)
plot(i_showProfile ? priorVAH : na, "pVAH", color=color.new(color.teal,    0), style=plot.style_linebr, linewidth=2)
plot(i_showProfile ? priorVAL : na, "pVAL", color=color.new(color.teal,    0), style=plot.style_linebr, linewidth=2)
plot(i_showProfile ? devPOC   : na, "dPOC", color=color.new(color.orange, 50), style=plot.style_linebr, linewidth=1)
plot(i_showProfile ? devVAH   : na, "dVAH", color=color.new(color.teal,   50), style=plot.style_linebr, linewidth=1)
plot(i_showProfile ? devVAL   : na, "dVAL", color=color.new(color.teal,   50), style=plot.style_linebr, linewidth=1)

// Step 2 sanity render — sideways histogram of the developing volume profile.
// Boxes are recycled each confirmed bar to stay well under the 500-box cap.
var array<box> devHistoBoxes = array.new<box>()

f_clearBoxes(arr) =>
    for b in arr
        box.delete(b)
    array.clear(arr)

// HVN / LVN band boxes — recycled per confirmed bar. Prior bands span from
// prior session's start through current bar (forward extension shows where
// today's price meets yesterday's structure). Dev bands span the live session.
var array<box> hvnBoxesPrior = array.new<box>()
var array<box> lvnBoxesPrior = array.new<box>()
var array<box> hvnBoxesDev   = array.new<box>()
var array<box> lvnBoxesDev   = array.new<box>()

f_renderZones(zones, leftBar, rightBar, fill) =>
    out = array.new<box>()
    if not na(leftBar)
        for z in zones
            b = box.new(leftBar, z.priceTop, rightBar, z.priceBot, border_color=na, bgcolor=fill)
            array.push(out, b)
    out

if barstate.isconfirmed
    f_clearBoxes(hvnBoxesPrior)
    f_clearBoxes(lvnBoxesPrior)
    f_clearBoxes(hvnBoxesDev)
    f_clearBoxes(lvnBoxesDev)
    if i_showNodes
        pHvn = f_renderZones(priorHvnZones, priorStartBar, bar_index, color.new(color.yellow,  88))
        pLvn = f_renderZones(priorLvnZones, priorStartBar, bar_index, color.new(color.fuchsia, 88))
        dHvn = f_renderZones(devHvnZones,   devStartBar,   bar_index, color.new(color.yellow,  92))
        dLvn = f_renderZones(devLvnZones,   devStartBar,   bar_index, color.new(color.fuchsia, 92))
        for b in pHvn
            array.push(hvnBoxesPrior, b)
        for b in pLvn
            array.push(lvnBoxesPrior, b)
        for b in dHvn
            array.push(hvnBoxesDev, b)
        for b in dLvn
            array.push(lvnBoxesDev, b)

if barstate.isconfirmed
    f_clearBoxes(devHistoBoxes)
    if i_showDevHistogram and not na(devAnchor)
        keys = devVolMap.keys()
        if array.size(keys) > 0
            maxV = 0.0
            for k in keys
                v = devVolMap.get(k)
                if v > maxV
                    maxV := v
            if maxV > 0
                for k in keys
                    v = devVolMap.get(k)
                    w = int((v / maxV) * i_histogramBars)
                    if w >= 1
                        binBot = f_binBottom(k, devAnchor, devRowSize)
                        binTop = f_binTop(k, devAnchor, devRowSize)
                        b = box.new(bar_index - w, binTop, bar_index, binBot, border_color=na, bgcolor=color.new(color.aqua, 70))
                        array.push(devHistoBoxes, b)


// ─── 12. ALERTS ─────────────────────────────────────────────────────────────
// Two layers:
//   1. Static alertcondition() — one per setup × side, plus a meta "any A+".
//      These are what users see in TV's alert-creation dialog.
//   2. Dynamic alert() — emits a JSON payload for any active setup graded
//      ≥ B. Fires once per bar close. Useful for webhook routing.

// Static "any A+" flag, computed across active setups.
hasAplus = false
if barstate.isconfirmed and array.size(activeSetups) > 0
    for s in activeSetups
        if s.grade == "A+"
            hasAplus := true
            break

alertcondition(isS1,      "BIG_OPP_LONG_FB_VAL",       "Long: Failed Breakdown Below VAL")
alertcondition(isS2,      "BIG_OPP_SHORT_FB_VAH",      "Short: Failed Breakout Above VAH")
alertcondition(isS3Long,  "BIG_OPP_LONG_80R",          "Long: 80% Value Rotation Up")
alertcondition(isS3Short, "BIG_OPP_SHORT_80R",         "Short: 80% Value Rotation Down")
alertcondition(isS4,      "BIG_OPP_LONG_IE",           "Long: Initiative Expansion Above VAH")
alertcondition(isS5,      "BIG_OPP_SHORT_IE",          "Short: Initiative Expansion Below VAL")
alertcondition(isS6Long,  "BIG_OPP_LONG_LVN",          "Long: LVN Air Pocket")
alertcondition(isS6Short, "BIG_OPP_SHORT_LVN",         "Short: LVN Air Pocket")
alertcondition(isS7Long,  "BIG_OPP_LONG_POC_MAGNET",   "Long: POC Magnet Reversion")
alertcondition(isS7Short, "BIG_OPP_SHORT_POC_MAGNET",  "Short: POC Magnet Reversion")
alertcondition(hasAplus,  "BIG_OPP_ANY_A_PLUS",        "Any setup graded A+")

// JSON-safe price formatter (na → "null" so the payload stays valid JSON).
f_fmtJsonNum(p) => na(p) ? "null" : str.tostring(p, format.mintick)

// Dynamic JSON alerts for any active setup with a non-empty grade.
if barstate.isconfirmed and array.size(activeSetups) > 0
    for s in activeSetups
        if s.grade != ""
            payload = "{" +
                 "\"symbol\":\""  + syminfo.tickerid     + "\"," +
                 "\"tf\":\""      + timeframe.period     + "\"," +
                 "\"setup\":\""   + s.name               + "\"," +
                 "\"code\":\""    + s.code               + "\"," +
                 "\"side\":\""    + s.side               + "\"," +
                 "\"grade\":\""   + s.grade              + "\"," +
                 "\"score\":"     + str.tostring(s.score)         + "," +
                 "\"entry\":"     + f_fmtJsonNum(close)            + "," +
                 "\"t1\":"        + f_fmtJsonNum(s.target1)        + "," +
                 "\"t2\":"        + f_fmtJsonNum(s.target2)        + "," +
                 "\"t3\":"        + f_fmtJsonNum(s.target3)        + "," +
                 "\"invalid\":"   + f_fmtJsonNum(s.invalidPrice)   +
                 "}"
            alert(payload, alert.freq_once_per_bar_close)
